# ヘテムルサーバー用 .htaccess
# UTF-8 エンコーディング
AddDefaultCharset UTF-8

# ディレクトリ内のindex.htmlを自動表示
DirectoryIndex index.html

# 末尾スラッシュの有無に対応
# /leak → /leak/ → /leak/index.html
RewriteEngine On

# HTTPS強制（独自SSL設定時に有効化）
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# ディレクトリが存在し、末尾スラッシュがない場合にスラッシュを追加
RewriteCond %{REQUEST_FILENAME} -d
RewriteCond %{REQUEST_URI} !/$
RewriteRule ^(.*)$ $1/ [R=301,L]

# ファイルが存在しない場合、ディレクトリ内のindex.htmlを探す
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/$1/index.html -f
RewriteRule ^(.*)$ /$1/index.html [L]

# エラーページ
ErrorDocument 404 /index.html

# キャッシュ設定
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 1 hour"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
</IfModule>

# Gzip圧縮
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript text/xml application/xml
</IfModule>
